# Supabase Configuration for Cloud Trade Journal
# Copy this file to `.streamlit/secrets.toml` and fill in your Supabase credentials
# 
# To get your credentials:
# 1. Go to https://supabase.com and sign in
# 2. Open your project → Settings → API → Copy values below
# 3. Keep secrets.toml LOCAL ONLY (git-ignored)

SUPABASE_URL = "https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY = "your_anon_key_here"
APP_BASE_URL = "http://localhost:8501"
